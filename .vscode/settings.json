{
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "files.exclude": {
        "**/.venv": true,
        "**/__pycache__": true
    },
    "editor.fontSize": 14,
    "notebook.cellToolbarLocation": "left",
    "jupyter.kernels.excludePythonEnvironments": [
        "${workspaceFolder}/.venv/bin/python"
    ]
}
